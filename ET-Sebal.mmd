classDef input fill:#d5e8d4,stroke:#82b366,color:#000
classDef calc fill:#dae8fc,stroke:#6c8ebf,color:#000
classDef anchor fill:#ffe6cc,stroke:#d79b00,color:#000
classDef loopStep fill:#fff2cc,stroke:#d6b656,color:#000
classDef result fill:#f8cecc,stroke:#b85450,color:#000

class A0,A1,B0,B1,B2,B3,C0,D3,G0,H2 input
class C1,C2,C3,C4,C5,D0,D1,D2,D4,D5,D6,E0,E1 calc
class F0,F1,F2,F3 anchor
class G1,G2,G3,G4,G5,G6,G7,G8,G9 loopStep
class G10,H0,H1,H3,H4,I0,I1 result
